<!-- res/drawable/bordered_shape.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Define the border (stroke) only -->
    <solid android:color="@color/earthBrown" />
    <stroke
        android:width="2dp"
        android:color="@color/black" />
    <!-- Color of the border -->

    <!-- Optional: Set rounded corners -->
    <corners android:radius="8dp" />

    <!-- Optional: Add padding inside the shape -->
    <padding
        android:left="4dp"
        android:right="4dp"
        android:top="4dp"
        android:bottom="4dp" />
</shape>
